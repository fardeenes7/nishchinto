# ─── API (server-only, NO NEXT_PUBLIC_ prefix) ──────────────────────────────
# Used by @repo/api fetchers (publicFetch, apiFetch) on the Node.js server.
# In Docker Compose this should be the internal service name:
#   API_BASE_URL=http://api:8000
# In local dev without Docker:
API_BASE_URL=http://localhost:8000

# ─── Public config (safe to expose to browser) ───────────────────────────────
# Used only for UI display (e.g., displayed in footer, og:url, etc.)
# NEVER put API_BASE_URL or secrets here.
NEXT_PUBLIC_ROOT_DOMAIN=nishchinto.com.bd
NEXT_PUBLIC_APP_URL=https://app.nishchinto.com.bd

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# SENTRY_DSN=

# ─── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
