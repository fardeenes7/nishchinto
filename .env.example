# ── Per-app env files live in apps/<name>/.env.local ─────────────────────────
# Copy the block below into apps/dashboard/.env.local, apps/storefront/.env.local
# and apps/admin/.env.local as needed. This root file is for documentation only
# and is NOT read by any app at runtime.

# ── Server-only (never prefix with NEXT_PUBLIC_) ─────────────────────────────
API_BASE_URL=http://localhost:8000   # Use http://api:8000 inside Docker

# ── Dashboard-specific ────────────────────────────────────────────────────────
# Placeholder shop ID until SSO session is wired (v0.4)
MOCK_SHOP_ID=

# ── Public ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=mohajon.io
NEXT_PUBLIC_APP_URL=https://app.mohajon.io
NEXT_PUBLIC_CDN_URL=https://cdn.mohajon.io

# ── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=

# ── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
